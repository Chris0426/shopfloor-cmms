# Copy to .env for local development. Values here are throwaway.
# In production every one of these is a Fly secret — see infra/secrets-manifest.md.
# All settings are prefixed CMMS_ (pydantic-settings, src/cmms/config.py).

CMMS_APP_ENV=local
CMMS_DATABASE_URL=postgresql+asyncpg://cmms:cmms@localhost:5432/cmms

# --- read API (service-to-service JSON contracts) ---------------------------
# Unset + APP_ENV=production => protected read endpoints return 503 (fail-closed, by design).
# Unset + local/CI => open, for convenience.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CMMS_READ_API_TOKEN=

# --- credential vault (per-user Jira PAT envelope encryption) ---------------
# Unset => the vault fails closed in production. There is no plaintext fallback.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CMMS_CREDENTIAL_MASTER_KEY=

# --- object storage (S3-compatible, e.g. Cloudflare R2) ---------------------
# All three unset => storage falls back to an in-memory backend (local/CI friendly).
# CMMS_R2_ENDPOINT=
# CMMS_R2_ACCESS_KEY_ID=
# CMMS_R2_SECRET_ACCESS_KEY=
# CMMS_R2_MEDIA_BUCKET=cmms-media

# --- notifications ----------------------------------------------------------
# SMTP: host + username + password all present => real sender, else in-memory (never sends).
# CMMS_SMTP_HOST=
# CMMS_SMTP_PORT=465
# CMMS_SMTP_USERNAME=
# CMMS_SMTP_PASSWORD=
# CMMS_NOTIFY_FROM=
# CMMS_TELEGRAM_BOT_TOKEN=
# CMMS_TELEGRAM_BOT_USERNAME=
# CMMS_TELEGRAM_WEBHOOK_SECRET=

# --- agent gateway (ADR-020) ------------------------------------------------
# Unset => the in-app assistant reports itself as unconfigured. It does not degrade silently.
# CMMS_HERMES_GATEWAY_URL=
# HERMES_GATEWAY_SECRET=

# --- Jira (ADR-020) ---------------------------------------------------------
# CMMS_JIRA_BASE_URL=
# CMMS_JIRA_PROJECT_KEY=

# --- on-box signed writes (ADR-017) -----------------------------------------
# Public keys of the edge tooling, as a static JWKS. Unset => the on-box API returns 503.
# CMMS_ONBOX_JWKS_JSON=
